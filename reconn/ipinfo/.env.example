# ─────────────────────────────────────────────────────────────────
# ipinfo.py — environment configuration
# ─────────────────────────────────────────────────────────────────
# Copy this file to the same folder as ipinfo.py and rename it to
# exactly:  .env
#
# How to get your token:
#   1. Sign up / log in at https://lite.ip2location.com
#   2. Go to the Download section
#   3. Copy the token shown on that page
#
# IMPORTANT: Never commit this file to version control (git).
#            Add  .env  to your  .gitignore  file.
# ─────────────────────────────────────────────────────────────────

# Your IP2Location LITE download token (required for --update)
IP2LOCATION_TOKEN=your_token_here

# Optional: override the folder where .BIN database files are stored.
# Default is the same directory as ipinfo.py itself.
# Use an absolute path or leave commented out.
#IP2LOCATION_DB_DIR=/opt/ip2location/databases