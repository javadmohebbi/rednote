# ──────────────────────────────────────────────────────────────────────────────
# ip2location.py — environment configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env in the same folder:
#   cp .env.example .env
#
# How to get your token:
#   1. Sign up / log in at https://lite.ip2location.com
#   2. Go to the Download section and copy your token.
#
# IMPORTANT: Never commit .env to version control — keep it in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# Your IP2Location LITE download token (required for --download and --update).
IP2LOCATION_TOKEN=your_token_here

# Optional: folder where .BIN database files are stored.
# Defaults to the same directory as ip2location.py.
# IP2LOCATION_DB_DIR=/opt/ip2location/databases
